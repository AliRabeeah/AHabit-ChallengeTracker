{
  "expo": {
    "name": "AHabit",
    "slug": "ahabit",
    "scheme": "ahabit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#000000",
    "splash": {
      "backgroundColor": "#000000"
    },
    "android": {
      "package": "com.alihalim.ahabit",
      "backgroundColor": "#000000",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": ["SCHEDULE_EXACT_ALARM", "RECEIVE_BOOT_COMPLETED", "POST_NOTIFICATIONS"]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#FF8A00"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TodayHabits",
              "label": "AHabit — Today",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 3,
              "description": "Shows today's habits with Done/Skip buttons",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            },
            {
              "name": "ProgressRing",
              "label": "AHabit — Progress",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "description": "Shows how much of today's habits are done",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            },
            {
              "name": "HabitFocus",
              "label": "AHabit — Focus Habit",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "description": "Pin one habit with a big Done button",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            },
            {
              "name": "WeeklyHeatmap",
              "label": "AHabit — Weekly Heatmap",
              "minWidth": "180dp",
              "minHeight": "80dp",
              "targetCellWidth": 3,
              "targetCellHeight": 1,
              "description": "7-day strip for one habit",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            },
            {
              "name": "QuickAdd",
              "label": "AHabit — Quick Add",
              "minWidth": "60dp",
              "minHeight": "60dp",
              "targetCellWidth": 1,
              "targetCellHeight": 1,
              "description": "One tap to open AHabit and add something",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            },
            {
              "name": "PomodoroTimer",
              "label": "AHabit — Pomodoro",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "description": "Shows your last-known Pomodoro phase and time",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ]
    ]
  }
}
